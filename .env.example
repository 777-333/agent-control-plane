# ============================================================================
# Agent Control Plane – Environment Configuration
# Copy this file to ".env" for local development and fill in real values.
# In production (Coolify), set these in the application's environment settings.
# ============================================================================

# --- Runtime ---------------------------------------------------------------
NODE_ENV=development
# Port the server binds to (Coolify/Traefik proxies to this).
PORT=3000
# Public origin of the deployed app, e.g. https://control-plane.example.com
# Used for cookies and auth redirects in production.
APP_ORIGIN=http://localhost:3000

# --- Database (Supabase Postgres) ------------------------------------------
# App connection (use the Supabase connection pooler, port 6543).
# Format: postgres://postgres.<ref>:<password>@<host>:6543/postgres
DATABASE_URL=

# --- Session ---------------------------------------------------------------
# Secret used to sign the httpOnly session cookie (jose / HS256).
# Generate a strong value, e.g.: openssl rand -base64 48
JWT_SECRET=

# --- Supabase Auth ---------------------------------------------------------
# Project URL, e.g. https://<ref>.supabase.co
SUPABASE_URL=
# Public anon key (safe to expose to the browser).
SUPABASE_ANON_KEY=
# Service role key (server-only, NEVER expose to the browser).
SUPABASE_SERVICE_ROLE_KEY=
# JWT secret from Supabase Auth settings (used to verify access tokens).
SUPABASE_JWT_SECRET=

# Client-side Supabase config (Vite exposes only VITE_*-prefixed vars).
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_APP_ID=agent-control-plane

# --- Observability (optional) ----------------------------------------------
# Sentry DSN; error tracking is disabled when empty.
SENTRY_DSN=

# --- Event ingestion -------------------------------------------------------
# Shared bearer token for POST /api/ingest (live agents push real events).
# Generate a strong value, e.g.: openssl rand -hex 32
INGEST_TOKEN=

# --- Development convenience login (non-production only) --------------------
# When set in development, GET /api/dev-login signs in this identity.
OWNER_OPEN_ID=
OWNER_NAME=
